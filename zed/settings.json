// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "icon_theme": "Bearded Icons",
  "project_panel": {
    "dock": "left",
  },
  "enable_language_server": true,
  "git_panel": {
    "tree_view": true,
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "buffer_font_family": "MesloLGS Nerd Font Mono",
  "colorize_brackets": true,
  "agent": {
    "model_parameters": [],
    "default_model": {
      "provider": "google",
      "model": "gemini-3-pro-preview",
    },
  },
  "ssh_connections": [
    {
      "host": "desktop",
      "projects": [
        {
          "paths": ["/home/cberg18/Documents/code/role-docker-tls"],
        },
        {
          "paths": ["~/Documents"],
        },
        {
          "paths": ["~/Documents/code/StockBot"],
        },
        {
          "paths": ["~/Documents/code/labOps"],
        },
      ],
    },
  ],
  "terminal": {
    "detect_venv": {
      "on": {
        // Default directories to search for virtual environments, relative
        // to the current working directory. We recommend overriding this
        // in your project's settings, rather than globally.
        "directories": [".env", "env", ".venv", "venv"],
        // Can also be `csh`, `fish`, and `nushell`
        "activate_script": "default",
      },
    },
  },
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "DevStreetLab Dark",
  },
  "semantic_tokens": "combined",
  "show_whitespaces": "boundary",
  "indent_guides": {
    // Whether to show indent guides in the editor.
    "enabled": true,
    // The width of the indent guides in pixels, between 1 and 10.
    "line_width": 1,
    // The width of the active indent guide in pixels, between 1 and 10.
    "active_line_width": 3,
    // Determines how indent guides are colored.
    // This setting can take the following three values:
    ///
    // 1. "disabled"
    // 2. "fixed"
    // 3. "indent_aware"
    "coloring": "indent_aware",
    // Determines how indent guide backgrounds are colored.
    // This setting can take the following two values:
    ///
    // 1. "disabled"
    // 2. "indent_aware"
    "background_coloring": "disabled",
  },
  "file_types": {
    "Dockerfile": ["Dockerfile.*"],
    "docker-compose": [
      "docker-compose.yml",
      "*.docker-compose.yml",
      "compose.yml",
      "docker-compose.yaml",
      "*.docker-compose.yaml",
      "compose.yaml",
    ],
    "Shell Script": [".zshrc"],
    "JSON": [".renovaterc", "*.tfstate", "*.tfstate.backup"],
    "Ansible": [
      "**/ansible/.ansible.yml",
      "**/ansible/.ansible.yaml",
      "**/ansible/defaults/*.yml",
      "**/ansible/defaults/*.yaml",
      "**/ansible/meta/*.yml",
      "**/ansible/meta/*.yaml",
      "**/ansible/tasks/*.yml",
      "**/ansible/tasks/*.yaml",
      "**/ansible/handlers/*.yml",
      "**/ansible/handlers/*.yaml",
      "**/ansible/group_vars/*.yml",
      "**/ansible/group_vars/*.yaml",
      "**/ansible/playbooks/*.yaml",
      "**/ansible/playbooks/*.yml",
      "**/ansible/playbook*.yaml",
      "**/ansible/playbook*.yml",
      "**/ansible/*.yml",
      "**/ansible/*.yaml",
    ],
  },
  "lsp": {
    "ansible": {
      "settings": {
        "ansible": {
          "path": "ansible",
        },
        "executionEnvironment": {
          "enabled": true,
        },
        "python": {
          "interpreterPath": ".venv/bin/python3",
        },
        "validation": {
          "enabled": true,
          "lint": {
            "enabled": true,
            "path": ".venv/bin/ansible-lint",
            "arguments": ["--fix"],
          },
        },
      },
    },
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemas": {
            "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/inventory.json": [
              "./inventory/*.yaml",
              "hosts.yml",
            ],
          },
        },
      },
    },
  },
  "languages": {
    "YAML": {
      "language_servers": ["yaml-language_servers", "!docker-compose"],
    },
    "Dockerfile": {
      "format_on_save": "on",
    },
    "Python": {
      "language_servers": [
        // Disable basedpyright and enable ty, and otherwise
        // use the default configuration.
        "ty",
        "ruff",
        "!basedpyright",
      ],
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
      "inlay_hints": {
        "enabled": true,
        "show_type_hints": true,
        "show_parameter_hints": true,
        "show_other_hints": true,
      },
    },
  },
}
